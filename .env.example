# Browser-exposed variables (safe to publish)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_TWITTER_HANDLE=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=
NEXT_PUBLIC_YAHOO_SITE_VERIFICATION=

# Canonical app origin used for admin mutation origin checks, canonical SEO URLs, sitemap, and robots host.
APP_ORIGIN=
# Optional comma-separated admin origins for trusted cross-origin admin mutations.
ADMIN_ALLOWED_ORIGINS=

# Server-only secret (never expose to browser/client bundle)
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
ENABLE_ADMIN_AUDIT_SUCCESS_LOGS=
ENABLE_ADMIN_AUDIT_CLIENT_ERROR_LOGS=
DISABLE_PUBLIC_COMPONENTS_CACHE=
DISABLE_RATE_LIMIT_FALLBACK_IN_MEMORY=
ENABLE_SHARED_RATE_LIMIT_FALLBACK_LOGS=
