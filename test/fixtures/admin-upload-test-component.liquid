{% assign heading_text = section.settings.heading | default: "Test Heading" %}
<section class="pp-test-component" style="padding:24px;border:1px solid #d4d4d8;border-radius:12px;">
  <h2>{{ heading_text }}</h2>

  {% if section.settings.body != blank %}
    <p>{{ section.settings.body }}</p>
  {% endif %}

  {% if section.settings.cta_url != blank %}
    <a href="{{ section.settings.cta_url }}">{{ section.settings.cta_label }}</a>
  {% endif %}
</section>

{% schema %}
{
  "name": "PressPlay Test Component",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Test Heading"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "This is a test component for admin upload validation."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "Learn more"
    }
  ],
  "presets": [
    {
      "name": "PressPlay Test Component"
    }
  ]
}
{% endschema %}
